{
  "manifest_version": 3,
  "name": "Blown Speaker Simulator",
  "version": "1.0",
  "description": "Simulates the sound of a blown-out car subwoofer by heavily distorting the bass frequencies in the active tab.",
  "permissions": ["tabCapture", "offscreen", "activeTab", "storage"],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  }
}
